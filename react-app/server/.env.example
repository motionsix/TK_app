# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (อย่า commit ไฟล์ .env)

# Server
PORT=3001

# Database: SQLite (เว้นว่างเพื่อใช้ไฟล์ default ที่ data/tk_easy.sqlite)
SQLITE_FILE=

# Auth — ต้องสุ่มเองเป็นสตริงยาว >= 32 ตัวอักษร
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES=7d

# CORS: origin ของ React dev server
CLIENT_ORIGIN=http://localhost:5173

# Loyverse POS (เว้นว่าง = ปิดการเชื่อมต่อ)
LOYVERSE_TOKEN=
LOYVERSE_STORE_ID=

# ซิงค์สินค้าอัตโนมัติทุกกี่นาที (default 30, ใส่ 0 = ปิดการซิงค์อัตโนมัติ)
LOYVERSE_SYNC_MINUTES=30

# รหัสผ่านเริ่มต้น (optional)
LOYVERSE_DEFAULT_PASSWORD=
LOYVERSE_ADMIN_PASSWORD=
