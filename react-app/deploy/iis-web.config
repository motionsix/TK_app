<?xml version="1.0" encoding="UTF-8"?>
<!--
  วางไฟล์นี้ (ชื่อ web.config) ไว้ใน Physical path ของเว็บไซต์ใน IIS
  เช่น C:\apps\tkstore\site\web.config

  ต้องติดตั้งก่อน: URL Rewrite + Application Request Routing (ARR)
  และเปิด proxy: IIS Manager -> คลิกชื่อเครื่อง (root) ->
                 Application Request Routing Cache -> Server Proxy Settings
                 -> ติ๊ก "Enable proxy" -> Apply

  จากนั้น reverse proxy ทุก request ไปที่ Node ที่ localhost:3001
  (ARR จะแนบ header X-Forwarded-For ให้อัตโนมัติ ใช้คู่กับ app.set('trust proxy', 1))
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3001/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
